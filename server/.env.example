# PostgreSQL connection string used by Prisma.
# Matches the credentials in docker-compose.yml for easy local dev.
DATABASE_URL="postgresql://gettoit:gettoit@localhost:5432/gettoit?schema=public"

# Port the Express API listens on.
PORT=4000

# Comma-separated list of allowed CORS origins (the Vite dev server).
CORS_ORIGIN="http://localhost:5173"
